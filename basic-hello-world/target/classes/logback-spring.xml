<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{transactionId:-NO-TXN}] %-5level %logger{36} - %msg%n"/>
    <property name="LOG_FILE" value="/home/deva/Desktop/logs/ai-catalina.log"/>

    <!-- Console appender — keeps Spring Boot's normal console behavior -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!--
        RollingFileAppender — writes to /home/deva/Desktop/logs/ai-catalina.log.
        Logback creates the parent directory automatically if it does not exist.
        Rolls daily and whenever the file exceeds 100 MB; keeps 30 days of history.
    -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>/home/deva/Desktop/logs/ai-catalina.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
