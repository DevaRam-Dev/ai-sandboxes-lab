# Copy this file to .env and fill in your real values.
# Then export the variables before starting the app:
#
#   export $(grep -v '^#' .env | xargs)
#   java -jar target/basic-hello-world-0.0.1-SNAPSHOT.jar
#
# Or pass directly on the command line:
#   E2B_API_KEY=e2b_xxx java -jar target/basic-hello-world-0.0.1-SNAPSHOT.jar
#
# Get your E2B API key from: https://e2b.dev/dashboard

E2B_API_KEY=e2b_your_api_key_here
